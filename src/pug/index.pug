include variable/navigationVar
include mixines/navigation
include mixines/title-for-section


doctype html
html(lang='ru')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Roasteria18
  body
    header.header
      .header__wr-content
        include components/logo
        +nav(nav)
      
    main.main 
      //- ------------------ Слайдер с видео

      .slider-h
        .slider-h__slides 
          ul.slider-h__slides-list 
            li.slider__slide-item
              video(controls muted autoplay data-count="0")
                source(src=require('../video/roasting-coffee-1.MOV') type='video/mp4')
            li.slider__slide-item
              video(controls muted autoplay data-count="1")
                source(src=require('../video/roasting-coffee-2.MOV') type='video/mp4')
            li.slider__slide-item
              video(controls muted autoplay data-count="2")
                source(src=require('../video/roasting-coffee-3.MOV') type='video/mp4')

        .slider-h__mask
        
        .slider-h__arrows-name 
          include components/arrow-prev

          .slider-h__wr-name-site
            .slider-h__wr-name-site-descr
              .slider-h__name-site-lines
                .slider-h__name-site-line.slider-h__name-site-line_top 
                .slider-h__name-site-line.slider-h__name-site-line_bottom 
              .slider-h__name-site-descr крафтовый кофе
              .slider-h__name-site-lines
                .slider-h__name-site-line.slider-h__name-site-line_top 
                .slider-h__name-site-line.slider-h__name-site-line_bottom 
            .slider-h__name-site Roasteria18

          include components/arrow-next
          
        .slider-h__pagination
          ul.slider-h__pagination-list
            li.slider-h__pagination-item(data-num="0")
              .slider-h__pagination-icon
              .slider-h__pagination-text Свежая обжарка
            li.slider-h__pagination-item(data-num="1")
              .slider-h__pagination-icon
              .slider-h__pagination-text Зерна
            li.slider-h__pagination-item(data-num="2")
              .slider-h__pagination-icon
              .slider-h__pagination-text Упаковка
        .slider-h__line 
          .slider-h__nav-line
            .slider-h__nav-line-item
      
            //- ------------------ блок со слайдерами с кофе

      .coffee 

        article.coffee__wr-slider-top
          include components/slider-coffee

        article.coffee__wr-slider-bottom
          include components/slider-coffee

        .coffee__side-deco

      section.merch 
        .merch__wr-title 
          +title-for-section('Мерч')
        .merch__wr-slider
          include components/slider-perspective

      section.accessories 
        .accessories__wr-title 
          +title-for-section('Аксессуары')
        .accessories__wr-slider
          include components/slider-perspective

      section.contacts
        .contacts__wr-title 
          +title-for-section('Контакты')
        .contacts__wr-data 
          .contacts__map 
            img(src=require('../img/map.png'), alt="Карта офиса R18")
          .contacts__wr-address
            .contacts__logo-mobile
              include components/logo
            .contacts__address 
              h3.contacts__address-title Адрес:
              p 
                span Береговая улица, 47Б
                span коттеджный поселок Спартак, село Быково,
                span Раменский городской округ, Московская область.
            .contacts__working-time
              h3.contacts__address-title Время работы: 09:00 - 18:00,
              p по рабочим дням.
            .contacts__phone-number
              .contacts__wr-phone-number
                h3.contacts__phone-number-title Для заказа и сотрудничества:
                a.contacts__phone-number-link(href="tel:+79060449550" title="для заказа и сотрудничества") +7 (906) 044-95-50 
              .button-to-top 
