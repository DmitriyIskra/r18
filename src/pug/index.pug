include variable/navigationVar
include mixines/navigation


doctype html
html(lang='ru')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Roasteria18
  body
    header.header
      .header__wr-nav
        a.logo(href="/")
          img(src=require("../img/logo.png"), alt="Логотип R18")
        +nav(nav)
      
    main.main 
      //- ------------------ Слайдер с видео

      .slider-h
        .slider-h__slides 
          ul.slider-h__slides-list 
            li.slider__slide-item
              video(controls="false" loop muted autoplay data-count="0")
                source(src=require('../video/IMG_0981.MOV') type='video/mp4')
              //- img(src=require('../img/content/fon-head-slider_content.png'), alt="Слайд")
            li.slider__slide-item
              video(controls="false" loop muted autoplay data-count="1")
                source(src=require('../video/IMG_0981.MOV') type='video/mp4')
              //- img(src=require('../img/content/fon-head-slider_content.png'), alt="Слайд")
            li.slider__slide-item
              video(controls="false" loop muted autoplay data-count="2")
                source(src=require('../video/IMG_0981.MOV') type='video/mp4')
              //- img(src=require('../img/content/fon-head-slider_content.png'), alt="Слайд")

        .slider-h__mask
        
        .slider-h__arrows-name 
          include components/arrow-prev

          .slider-h__wr-name-site
            .slider-h__wr-name-site-descr
              .slider-h__name-site-lines
                .slider-h__name-site-line.slider-h__name-site-line_top 
                .slider-h__name-site-line.slider-h__name-site-line_bottom 
              .slider-h__name-site-descr крафтовый кофе
              .slider-h__name-site-lines
                .slider-h__name-site-line.slider-h__name-site-line_top 
                .slider-h__name-site-line.slider-h__name-site-line_bottom 
            .slider-h__name-site Roasteria18

          include components/arrow-next
          
        .slider-h__pagination
          ul.slider-h__pagination-list
            li.slider-h__pagination-item(data-num="0")
              .slider-h__pagination-icon
              .slider-h__pagination-text Название видео про обжарку, название видео про обжарку
            li.slider-h__pagination-item(data-num="1")
              .slider-h__pagination-icon
              .slider-h__pagination-text Название видео про обжарку, название видео про обжарку
            li.slider-h__pagination-item(data-num="2")
              .slider-h__pagination-icon
              .slider-h__pagination-text Название видео про обжарку, название видео про обжарку
        .slider-h__line 
          .slider-h__nav-line
            .slider-h__nav-line-item
      
            //- ------------------ блок со слайдерами с кофе

      .coffee 

        article.coffee__wr-slider-top
          include components/slider-coffee

        article.coffee__wr-slider-bottom
          include components/slider-coffee

        .coffee__side-deco

      section.merch 
        .merch__wr-title 
          h2.merch__title Мерч
        .merch__wr-slider
          include components/slider-perspective

    